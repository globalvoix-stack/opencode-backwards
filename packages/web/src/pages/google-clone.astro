---
// Google Clone Landing Page
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Google</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: Arial, sans-serif;
            background-color: #fff;
            color: #202124;
            line-height: 1.6;
        }
        
        .container {
            max-width: 500px;
            margin: 0 auto;
            padding: 20px;
            text-align: center;
        }
        
        .logo-container {
            margin-top: 80px;
            margin-bottom: 20px;
        }
        
        .logo {
            font-family: 'Google Sans', Roboto, Arial, sans-serif;
            font-size: 4rem;
            font-weight: bold;
            letter-spacing: -5px;
            background: linear-gradient(45deg, #4285F4, #EA4335, #FBBC05, #34A853);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .search-box {
            position: relative;
            max-width: 580px;
            margin: 0 auto 30px;
        }
        
        .search-input {
            width: 100%;
            padding: 12px 16px 12px 40px;
            border: 1px solid #dadce0;
            border-radius: 24px;
            font-size: 16px;
            box-shadow: 0 1px 6px rgba(32,33,36,.28);
            outline: none;
            transition: box-shadow 0.2s;
        }
        
        .search-input:focus {
            box-shadow: 0 1px 6px rgba(0,0,0,.2);
            border-color: #d9d9d9;
        }
        
        .search-icon {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #9aa0a6;
            width: 20px;
            height: 20px;
        }
        
        .voice-icon {
            position: absolute;
            right: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #9aa0a6;
            width: 20px;
            height: 20px;
        }
        
        .buttons {
            margin-bottom: 30px;
        }
        
        .btn {
            background-color: #f8f9fa;
            border: 1px solid #f8f9fa;
            border-radius: 4px;
            color: #3c4043;
            font-family: arial, sans-serif;
            font-size: 14px;
            margin: 0 4px;
            padding: 0 12px;
            line-height: 27px;
            height: 36px;
            min-width: 54px;
            text-align: center;
            cursor: pointer;
            user-select: none;
            transition: background-color .218s, border-color .218s, box-shadow .218s;
        }
        
        .btn:hover {
            box-shadow: 0 1px 1px rgba(0,0,0,.1);
            background-color: #f8f9fa;
            border: 1px solid #dadce0;
            color: #202124;
        }
        
        .btn:active {
            background-color: #f6f6f6;
        }
        
        .language {
            font-size: small;
            color: #5f6368;
            margin-bottom: 20px;
        }
        
        .language a {
            color: #1a0dab;
            text-decoration: none;
            margin: 0 3px;
        }
        
        .language a:hover {
            text-decoration: underline;
        }
        
        .footer {
            position: absolute;
            bottom: 0;
            width: 100%;
            background-color: #f2f2f2;
            border-top: 1px solid #e4e4e4;
            font-size: 14px;
        }
        
        .footer-left {
            float: left;
            padding-left: 20px;
        }
        
        .footer-right {
            float: right;
            padding-right: 20px;
        }
        
        .footer a {
            color: #5f6368;
            text-decoration: none;
            margin: 0 10px;
            line-height: 40px;
        }
        
        .footer a:hover {
            text-decoration: underline;
        }
        
        .footer::after {
            content: "";
            display: table;
            clear: both;
        }
        
        @media (max-width: 600px) {
            .logo {
                font-size: 3rem;
            }
            
            .search-input {
                padding: 12px 16px 12px 35px;
                font-size: 15px;
            }
            
            .footer-left, .footer-right {
                float: none;
                width: 100%;
                text-align: center;
                margin: 10px 0;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="logo-container">
            <div class="logo">G o o g l e</div>
        </div>
        
        <div class="search-box">
            <div class="search-icon">🔍</div>
            <input type="text" class="search-input" placeholder="Google Search" aria-label="Search">
            <div class="voice-icon">🎤</div>
        </div>
        
        <div class="buttons">
            <button class="btn">Google Search</button>
            <button class="btn">I'm Feeling Lucky</button>
        </div>
        
        <div class="language">
            Google offered in: <a href="#">English</a>
        </div>
    </div>
    
    <div class="footer">
        <div class="footer-left">
            <a href="#">Advertising</a>
            <a href="#">Business</a>
            <a href="#">How Search works</a>
        </div>
        <div class="footer-right">
            <a href="#">Privacy</a>
            <a href="#">Terms</a>
            <a href="#">Settings</a>
        </div>
    </div>
</body>
</html>